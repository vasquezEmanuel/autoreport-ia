# ── Normalizar saltos de línea al hacer commit ────────
# Git convierte a LF al guardar, sin importar el OS
* text=auto eol=lf

# ── Archivos que siempre deben ser LF ─────────────────
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.prisma text eol=lf
*.sh     text eol=lf

# ── Archivos binarios: Git no los modifica ─────────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.pdf    binary
*.xlsx   binary
*.zip    binary