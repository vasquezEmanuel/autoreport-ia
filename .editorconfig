# editorconfig.org
root = true

# ── Todos los archivos ────────────────────────────────
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ── Markdown: no eliminar espacios al final ───────────
# En Markdown, 2 espacios al final de línea = salto de línea
[*.md]
trim_trailing_whitespace = false

# ── Prisma schema ─────────────────────────────────────
[*.prisma]
indent_size = 2

# ── Docker y YAML ─────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2